# .clangd — clangd language server configuration for PicoTeachOS
#
# This tells clangd where to find headers when a compile_commands.json
# generated by the Pico SDK / CMake is not yet available.
#
# Once you have run:
#   cmake -B build -DPICO_SDK_PATH=/path/to/pico-sdk
# the generated build/compile_commands.json will replace these flags
# automatically.  Point clangd at it with:
#   ln -s build/compile_commands.json compile_commands.json

CompileFlags:
  Add:
    # Internal source directories so that #include "vfs.h" etc. resolve.
    - -Isrc
    - -Isrc/kernel
    - -Isrc/shell
    - -Isrc/apps
    - -std=c11

Diagnostics:
  # Suppress warnings that are expected when building without the full SDK.
  Suppress:
    - pp_file_not_found
