#!/usr/bin/bash
# clean — remove all variant build directories and the test build directory

mkdir -p kits

for board in pico picow pico2 pico2w; do
    for disp in ND D D2; do
        dir="build_${board}_${disp}"
        if [ -d "$dir" ]; then
            echo "Cleaning $dir..."
            rm -rf "$dir"
        fi
    done
done

if [ -d "tests/build" ]; then
    echo "Cleaning tests/build..."
    rm -rf "tests/build"
fi
